{
  "name": "cerebras-agent",
  "version": "0.1.0",
  "description": "A terminal AI coding agent powered by Cerebras.",
  "type": "module",
  "bin": {
    "cerebras-agent": "./dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --dir test",
    "lint": "eslint src test"
  },
  "dependencies": {
    "@cerebras/cerebras_cloud_sdk": "^1.49.0",
    "commander": "^14.0.0",
    "diff": "^8.0.2",
    "dotenv": "^17.4.2",
    "execa": "^9.6.0",
    "ink": "^6.5.1",
    "react": "^19.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/diff": "^7.0.2",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "eslint": "^9.34.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
